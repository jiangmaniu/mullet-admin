# === 环境变量没有通过define 注入不会打包到代码中 ===

# ！！！！注意：这里是为了本地开发调试方便使用的环境变量，线上部署会使用接口读取/public/platform/config.json内容

# 按需把public/platform/config.json配置同步过来
# 平台名称
name=Mullet
# 平台简称-唯一标识
platform=sux
# 描述
desc=Mullet

# ========= mullet 本地对接后台环境 ================
# 接口地址
BASE_URL=http://192.168.5.203:8280
# 图片域名前缀
WS_URL=ws://192.168.5.203:19109/websocketServer
# 图片域名前缀
IMG_DOMAIN=http://192.168.5.203:9000/trade/
# 客户端ID
CLIENT_ID=trade-pc-manager
# 客户端密钥
CLIENT_SECRET=trade-pc-manager-secret